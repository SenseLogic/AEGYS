fn get_age_interval(
    sorted_person_array: []const Person
    ) ?AgeInterval
{
    if ( sorted_person_array.len == 0 )
    {
        return null;
    }
    else
    {
        return
            AgeInterval
            {
                .first_age = sorted_person_array[ 0 ].being.age,
                .last_age = sorted_person_array[ sorted_person_array.len - 1 ].being.age,
            };
    }
