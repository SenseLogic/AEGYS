            ) void
        {
            if ( age > 0
                 and age < 50
                 and ( age < 20
                       or age > 40 ) )
            {
                self.being.age
                    += ( age
                        + ( age - 2 )
                        + ( age
                            * ( age + 10 )
                            * ( age + 20 ) ) )
                        + self.get_age_offset(
